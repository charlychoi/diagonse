# ─────────────────────────────────────────────────────────────
# AI 프로바이더 (진단 전체를 AI로 구동)
# ─────────────────────────────────────────────────────────────

# 공개(배포) 버전 — Claude 사용. 이 키가 있으면 공개 버전이 AI로 동작합니다.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5

# 내부 테스트 전용 — xAI Grok / OpenAI GPT / Google Gemini 중 택 1.
# 아래 AI_MODE=internal 일 때만 동작하며, 공개 트래픽에서는 절대 사용되지 않습니다.
# 여러 키를 동시에 넣었다면 AI_PROVIDER로 명시 선택하세요(xai|openai|gemini).
# 비워두면 xai → openai → gemini 순으로 값이 있는 첫 번째 키를 사용합니다.
AI_MODE=
AI_PROVIDER=

XAI_API_KEY=
XAI_MODEL=grok-4.5

OPENAI_API_KEY=
OPENAI_MODEL=gpt-5

GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-pro

# 선택: 키워드 3층 전략도 AI로 생성
AI_KEYWORD_STRATEGY=false

# 선택: localhost 진단 라우트 보호
DIAGNOSE_API_KEY=
