# AI를 설정하지 않으면 안전한 규칙 기반 진단으로 동작합니다.
AI_MODE=
AI_PROVIDER=

# ── 방법 1: 저장소 복제 사용자의 자체 API 키 ─────────────────
# AI_PROVIDER=anthropic|openai|gemini|xai 중 하나를 선택하고
# 선택한 서비스의 키만 .env.local에 넣으세요.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5

OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.6

GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-pro

XAI_API_KEY=
XAI_MODEL=grok-4.5

# ── 방법 2: 이 Mac에서만 CLI OAuth 사용(키 입력 불필요) ──────
# 먼저 터미널에서 `grok login --oauth` 또는 `codex login`을 완료하세요.
# 아래 두 줄의 주석을 풀고 grok 또는 codex 중 하나를 선택합니다.
# AI_MODE=local-oauth
# AI_PROVIDER=grok
GROK_MODEL=grok-4.5
CODEX_MODEL=gpt-5.6

# 선택: 키워드 3층 전략도 AI로 생성
AI_KEYWORD_STRATEGY=false

# 선택: localhost 진단 라우트 보호
DIAGNOSE_API_KEY=
