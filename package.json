{
  "name": "diagonse",
  "version": "1.0.0",
  "private": true,
  "description": "Web marketing diagnosis: homepage URL + company name → Markdown / HTML / PDF report",
  "scripts": {
    "dev": "next dev --webpack -H 127.0.0.1",
    "build": "next build --webpack",
    "build:sites": "WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext build",
    "start": "next start -H 127.0.0.1",
    "diagnose": "tsx scripts/diagnose-cli.ts",
    "test": "tsx --test tests/*.test.ts"
  },
  "engines": {
    "node": ">=22.13.0"
  },
  "dependencies": {
    "marked": "^18.0.6",
    "next": "16.2.6",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "react-markdown": "^10.1.0",
    "rehype-slug": "^6.0.0",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "1.37.1",
    "@types/node": "22.19.19",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "@vitejs/plugin-rsc": "0.5.26",
    "react-server-dom-webpack": "19.2.6",
    "tsx": "4.20.4",
    "typescript": "5.9.3",
    "vinext": "0.0.50",
    "vite": "8.0.13",
    "wrangler": "4.92.0"
  },
  "type": "module"
}
